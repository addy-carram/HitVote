<Window x:Class="HitVote.Views.MainPanel.MainPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HitVote.Views.MainPanel"
        mc:Ignorable="d"
        Title="MainPanel" Height="700" Width="1440">
    <Grid Background="{DynamicResource BackgroundColor}">
        <StackPanel x:Name="panelElemets" Width="300" HorizontalAlignment="Left" Background="{DynamicResource BackgroundCard}">
            <Image Height="64" Width="64" Source="/Views/MainPanel/logo.png" Margin="40,44,40,40" HorizontalAlignment="Left"/>
            <Button x:Name="home" Background="{x:Null}" Padding="40,5,5,5" Height="81" HorizontalContentAlignment="Left" BorderBrush="{x:Null}"
                     MouseLeftButtonDown="Home_Click" Cursor="Hand">
                <StackPanel x:Name="home_context" Width="NaN" Orientation="Horizontal" Margin="10,10,10,10">
                    <Image Height="32" Width="32" Source="/Views/MainPanel/home.png"/>
                    <Label Content="Home" HorizontalAlignment="Left" Style="{StaticResource nav}" Margin="10,0,0,0"/>

                </StackPanel>
            </Button>
            <Button x:Name="vote" Background="{x:Null}" Padding="40,5,5,5" Height="81" HorizontalContentAlignment="Left" BorderBrush="{x:Null}" Click="vote_Click_1">
                <StackPanel x:Name="vote_context" Width="NaN" Orientation="Horizontal" Margin="10,10,10,10">
                    <Image Height="32" Width="32" Source="/Views/MainPanel/vote.png"/>
                    <Label Content="Vote" HorizontalAlignment="Left" Style="{StaticResource nav}" Margin="10,0,0,0"/>

                </StackPanel>
            </Button>
            <Button x:Name="person" Background="{x:Null}" Padding="40,5,5,5" Height="81" HorizontalContentAlignment="Left" BorderBrush="{x:Null}">
                <StackPanel x:Name="person_context" Width="NaN" Orientation="Horizontal" Margin="10,10,10,10">
                    <Image Height="32" Width="32" Source="/Views/MainPanel/person.png"/>
                    <Label Content="Person" HorizontalAlignment="Left" Style="{StaticResource nav}" Margin="10,0,0,0"/>

                </StackPanel>
            </Button>
            <Button x:Name="music" Background="{x:Null}" Padding="40,5,5,5" Height="81" HorizontalContentAlignment="Left" BorderBrush="{x:Null}">
                <StackPanel x:Name="music_context" Width="NaN" Orientation="Horizontal" Margin="10,10,10,10">
                    <Image Height="32" Width="32" Source="/Views/MainPanel/music.png"/>
                    <Label Content="Music" HorizontalAlignment="Left" Style="{StaticResource nav}" Margin="10,0,0,0"/>

                </StackPanel>
            </Button>
            <Button x:Name="raport" Background="{x:Null}" Padding="40,5,5,5" Height="81" HorizontalContentAlignment="Left" BorderBrush="{x:Null}">
                <StackPanel x:Name="raport_context" Width="NaN" Orientation="Horizontal" Margin="10,10,10,10">
                    <Image Height="32" Width="32" Source="/Views/MainPanel/report.png"/>
                    <Label Content="Raport" HorizontalAlignment="Left" Style="{StaticResource nav}" Margin="10,0,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
        <StackPanel x:Name="nav_bar" VerticalAlignment="Top" Height="100" Width="1140" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBox Style="{StaticResource InputBox}" TextWrapping="Wrap" Text="TextBox" Width="240" VerticalAlignment="Center" Margin="100,0,300,0"/>
            <StackPanel x:Name="user_elemets" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="200.4,0,0,0">
                <StackPanel x:Name="notification" Orientation="Horizontal">
                    <Image Height="32" Width="32" Source="/Views/MainPanel/ep_setting.png"/>
                    <Image Height="32" Width="32" Source="/Views/MainPanel/notification.png" Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel x:Name="___account_" Orientation="Horizontal" Height="100" Margin="30,0,0,0">
                    <Image Height="48" Width="48" Source="/Views/MainPanel/user1.jpg"/>
                    <Label Content="Account" Style="{StaticResource nav}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
        <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Height="485" Width="1135" Margin="0,129,0,0"/>

        <ContentControl x:Name="MainContent" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Top" 
                Height="600" Width="1135" 
                Margin="300,100,0,0"/>
    </Grid>
</Window>
