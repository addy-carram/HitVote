<UserControl x:Class="HitVote.Views.MainPanel.Music.MusicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HitVote.Controls"
             xmlns:vm="clr-namespace:HitVote.ViewModels">

    <UserControl.DataContext>
        <vm:MusicViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
>
        <StackPanel Margin="20">

            <!-- SONGS LIST -->
            
            
            <TextBlock Text="All songs" 
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="18" FontWeight="Bold"
                       Margin="0,20,0,10"/>

            <ItemsControl ItemsSource="{Binding Songs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:SongCard
                        Title="{Binding SongName}"
                        Artist="{Binding SingerName}"
                        ImageSource="{Binding SongImage}"
                        Duration="{Binding DurationFormatted}"
                        Date="{Binding DateLog, StringFormat=dd/MM/yyyy}"
                        Active="{Binding status}"
                        TotalPoints="{Binding TotalPoints}"
                        VoteCount="{Binding VoteCount}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>