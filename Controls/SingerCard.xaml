<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="HitVote.Controls.SingerCard"
             x:Name="root" Width="120" av:DesignHeight="125">

    <StackPanel HorizontalAlignment="Center" Margin="10">

        <!-- Round Avatar -->
        <Border Width="80" Height="80" 
                CornerRadius="100"
                ClipToBounds="True"
                HorizontalAlignment="Center">
            <Image Source="{Binding ImageSource, ElementName=root}" 
                   Stretch="UniformToFill"  />
        </Border>

        <!-- Singer Name -->
        <TextBlock Text="{Binding SingerName, ElementName=root}"
                   Foreground="{DynamicResource TextPrimary}"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>
    </StackPanel>
</UserControl>