<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="PrimaryColor"    Color="#F09200"/>
    <SolidColorBrush x:Key="BackgroundCard"  Color="#7F000000"/>
    <RadialGradientBrush x:Key="BackgroundColor" GradientOrigin="0,0" 
                         Center="0,0" 
                         RadiusX="1" RadiusY="1
                                 ">
        <GradientStop Color="#FFF09200" Offset="0.245"/>
        <GradientStop Color="#0A0A0A" Offset="1"/>
        <GradientStop Color="#FF362204" Offset="0.79"/>
    </RadialGradientBrush>
    <SolidColorBrush x:Key="TextPrimary"     Color="#FFE8C5"/>
    <SolidColorBrush x:Key="Inputs"          Color="#26F09200"/>
    <SolidColorBrush x:Key="TextParagraph"   Color="#CF953A"/>
        <SolidColorBrush x:Key="BorderColor"     Color="#FFFFE8C5"/>

</ResourceDictionary>