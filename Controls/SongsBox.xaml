<UserControl x:Class="HitVote.Controls.SongsBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HitVote.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="300">
    <Border Background="{DynamicResource BackgroundCard}"  
        >
        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
            <Image Height="80" Width="80" Margin="0,0,10,0"/>
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" >
                <Label Style="{DynamicResource kpi-title}" Content="Label"/>
                <Label Style="{DynamicResource kpi-paragraph}" Content="Label" Margin="0,5,0,0"/>
            </StackPanel>
        </StackPanel>

    </Border>

</UserControl>
