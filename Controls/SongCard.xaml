<UserControl x:Class="HitVote.Controls.SongCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HitVote.Converters"
             x:Name="root">

    <UserControl.Resources>
        <converters:StringToImageConverter x:Key="StringToImage"/>
    </UserControl.Resources>

    <Border CornerRadius="0" Margin="0,0,0,10" Padding="10">
        <StackPanel Orientation="Horizontal">
            <StackPanel>
                <StackPanel Width="400" Height="450">
                    <!-- Image -->
                    <Border CornerRadius="6" ClipToBounds="True">
                        <Image Source="{Binding ImageSource, ElementName=root, 
                                       Converter={StaticResource StringToImage}}" 
                               Stretch="Fill" Width="400" Height="400" 
                               HorizontalAlignment="Left"/>
                    </Border>
                    <!-- Play Button -->
                    <Button Content="▶" 
                            Width="36" Height="36"
                            Style="{DynamicResource PrimaryButton}" 
                            Margin="30,-80,30,0" 
                            HorizontalAlignment="Left"/>
                    <!-- Title + Artist -->
                    
                </StackPanel>
            </StackPanel>
            <StackPanel VerticalAlignment="Center" Margin="12,20,0,0" HorizontalAlignment="Left">
                <TextBlock Text="{Binding Title, ElementName=root}"
               Foreground="{DynamicResource TextPrimary}"
               FontSize="14" FontWeight="SemiBold" 
               HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding Artist, ElementName=root}"
               Foreground="{DynamicResource PrimaryColor}"
               FontSize="12" HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding Duration, ElementName=root}"
               Foreground="{DynamicResource PrimaryColor}"
               FontSize="12" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding Date, ElementName=root}"
               Foreground="{DynamicResource PrimaryColor}"
               FontSize="12" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding Active, ElementName=root}"
               Foreground="{DynamicResource PrimaryColor}"
               FontSize="12" HorizontalAlignment="Left"/>
            </StackPanel>

            
        </StackPanel>
    </Border>
</UserControl>